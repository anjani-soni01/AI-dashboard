PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/ai_notice_board
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional AI summary support. If blank, backend returns an extractive fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional mail/provider fields for future reminder email delivery.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
